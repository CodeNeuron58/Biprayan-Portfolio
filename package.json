    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "sass": "^1.69.0",
    "terser": "^5.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "gsap": "^3.15.0"
  }
